# ============================================================
# HAVENLY DASHBOARD — ENVIRONMENT VARIABLES
# The Black Sheep Tech Corp LTD (PTY)
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# --- NEXTAUTH CORE ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://dashboard.havenly.co.za"

# --- DASHBOARD API ---
# Backend API URL for authentication and data fetching
NEXT_PUBLIC_DASHBOARD_API_URL="http://localhost:3001"
# Production: NEXT_PUBLIC_DASHBOARD_API_URL="https://api.havenly.co.za"

# --- SOCKET.IO (Real-time Updates) ---
# Must match NEXT_PUBLIC_DASHBOARD_API_URL
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- MAPBOX (Dashboard Maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiLi4uIn0..."

# --- GOOGLE MAPS (Optional - for fallback mapping) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."

# --- SOCKET.IO (Real-time — set to your backend URL) ---
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# Production: NEXT_PUBLIC_SOCKET_URL="https://api.havenly.co.za"

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Havenly Command Centre"
NEXT_PUBLIC_LAUNCH_DATE="2026-11-24T00:00:00+02:00"

# --- OBSERVABILITY ---
# Sentry DSN for error tracking (Client & Server)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
