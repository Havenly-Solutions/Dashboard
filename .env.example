# ---------------------------------------------------------------------------
# Havenly Dashboard \u2014 environment variables
# Copy to .env.local for development. In production set these in your host
# (Vercel/Render/etc). Anything prefixed NEXT_PUBLIC_ is sent to the browser
# \u2014 never put secrets there.
# ---------------------------------------------------------------------------

# Base URL of havenly-backend, no trailing slash.
# Local:  http://localhost:4000
# Prod:   https://api.havenly.io
NEXT_PUBLIC_API_URL=http://localhost:4000

# Socket.io endpoint (usually same host/port as the API).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# When true, screens fall back to realistic seeded data if an API call
# fails (404/network error) so the UI can be reviewed before every backend
# route exists. Set to false in production once havenly-backend/src/dashboard
# is fully wired.
NEXT_PUBLIC_DEMO_MODE=true

# Public marketing site (havenly-marketing) base URL \u2014 used for "View live site"
# links from the Marketing analytics screen.
NEXT_PUBLIC_MARKETING_SITE_URL=https://www.havenly.solutions

# Mapbox GL JS token for the live SOS Incident Map.
# IMPORTANT: this must be a PUBLIC token (starts with "pk."), not the secret
# token you gave havenly-backend. Mapbox issues both from the same account:
#   - pk.\u2026 public token  \u2192 goes here, safe to expose in the browser, scope it
#     to your domain in the Mapbox dashboard (Tokens \u2192 URL restrictions).
#   - sk.\u2026 secret token   \u2192 stays server-side only, used for things like
#     reverse geocoding SOS addresses \u2014 that's what the backend key is for.
# Get a public token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
