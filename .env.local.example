# ─── NEXTAUTH ────────────────────────────────────────────────────
NEXTAUTH_SECRET=                                    # openssl rand -base64 32  →  paste here
NEXTAUTH_URL=http://localhost:3000                # Local dev: http://localhost:3000 | Prod: https://dashboard.havenly.solutions

# ─── DASHBOARD API ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.havenly.solutions           # Local: http://localhost:3005 | Prod: https://api.havenly.solutions

# ─── SOCKET.IO ───────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=https://api.havenly.solutions                  # Must match NEXT_PUBLIC_API_URL

# ─── MAPS ────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=                          # mapbox.com → Account → Access Tokens
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=                   # console.cloud.google.com → APIs → Credentials
NEXT_PUBLIC_SENTRY_DSN=